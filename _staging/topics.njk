---
layout: layouts/base.njk
pageTitle: "Topics: Gareth de Walters' personal website"
pageSummaryDefault: Browse this site by topic
pageSummaryMobile: Browse this site by topic
seoTitle: "Topics: Gareth de Walters' personal website"
seoDescription: Browse this site by topic
canonicalURL: https://garethdewalters.com/topics
opengraphTitle: "Topics: Gareth de Walters' personal website"
opengraphDescription: Browse this site by topic
pagination:
  data: collections
  size: 1
  alias: tag
  filter:
    - all
    - post
    - tagList
eleventyComputed:
  title: Tagged “{{ tag }}”
---
<section class="page-header section-sm">
  <div class="container">
    <div class="row">
      <div class="col-lg-12 text-center">
        <h1 class="section-title h2 mb-3">
          <span>Topics</span>
        </h1>
        <ul class="list-inline breadcrumb-menu mb-3">
          <li class="list-inline-item"><a href="/"><i class="ti ti-home"></i>  <span>Home</span></a></li>
          <li class="list-inline-item">• &nbsp; <a href="#"><span>Topics</span></a></li>
        </ul>
      </div>
    </div>
  </div>
</section>

<div class="container">
	<div class="row g-4 justify-content-center text-center">
	{% for tag in collections | getKeys | filterTagList %}
		{% set tagUrl %}/topics/{{ tag | slugify }}/{% endset %}

		<div class="col-lg-4 col-sm-6">
		<a class="p-4 rounded bg-white d-block is-hoverable" href="{{ tagUrl }}"{{ tag }}>
			<span class="h3"><i class="ti ti-folder mb-2"></i></span>
			<span class="h4 mt-2 mb-3 d-block"> {{ tag | capitalize }}</span>
		</a>
		</div>
	{% endfor %}
  </div>
</div>