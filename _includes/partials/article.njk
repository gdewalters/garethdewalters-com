    <section class="section-sm pb-0">
      <div class="container">
        <div class="row justify-content-center">
          <div class="col-lg-10">
            <div class="mb-5">
              <h3 class="h1 mb-4 post-title">{{ title }}</h3>            

              <ul class="card-meta list-inline mb-2">
                <li class="list-inline-item mt-2">
                  <i class="ti ti-writing"></i>
                  <a href="author-single.html" class="" title="Read all posts by - Gareth de Walters">
                  <span>By Gareth de Walters</span>
                  </a>
                </li>
                <li class="list-inline-item mt-2">—</li>
                <li class="list-inline-item mt-2">
                  <i class="ti ti-clock"></i>
                  <span>{{ content | readingTime }} read</span>
                </li>
                <li class="list-inline-item mt-2">—</li>
                <li class="list-inline-item mt-2">
                  <i class="ti ti-calendar-event"></i>
                  <span>{{ page.date | readableDate }}</span>
                </li>
              </ul>
              
            </div>
          </div>
          <div class="col-lg-12">
          {% if featuredImage %}
            <figure class="mb-5 text-center">
              <img class="w-100 h-auto rounded" src="{{featuredImage}}" alt="{{title}}" width="970" height="500">
              <figcaption>{{featuredImageCaption}}</figcaption>
            </figure>
          {% endif %}
          </div>
          <div class="col-lg-2 post-share-block order-1 order-lg-0 mt-5 mt-lg-0">
            <div class="position-sticky" style="top:150px">
              <span class="d-inline-block mb-3 small">SHARE</span>
              <ul class="social-share icon-box">
                <li class="d-inline-block d-lg-block me-2 mb-2" onclick="return tbs_click()"><i class="ti ti-brand-twitter"></i></li>
                <li class="d-inline-block d-lg-block me-2 mb-2" onclick="return fbs_click()"><i class="ti ti-brand-facebook"></i></li>
                <li class="d-inline-block d-lg-block me-2 mb-2" onclick="return ins_click()"><i class="ti ti-brand-linkedin"></i></li>
                <li class="d-inline-block d-lg-block me-2 mb-2" onclick="return red_click()"><i class="ti ti-brand-reddit"></i></li>
                <li class="d-inline-block d-lg-block me-2 mb-2" onclick="return pin_click()"><i class="ti ti-brand-pinterest"></i></li>
              </ul>
            </div>
            <script type="text/javascript">
              var pageLink = window.location.href;
              var pageTitle = String(document.title).replace(/\&/g, '%26');
              function tbs_click(){pageLink = 'https://twitter.com/intent/tweet?text={{title}}&url={{ metadata.url }}{{ page.url }}';socialWindow(pageLink, 570, 570);}
              function fbs_click(){pageLink = 'https://www.facebook.com/sharer.php?u={{ metadata.url }}{{ page.url }}&quote={{title}}';socialWindow(pageLink, 570, 570);}
              function ins_click(){pageLink = 'https://www.linkedin.com/sharing/share-offsite/?url={{ metadata.url }}{{ page.url }}';socialWindow(pageLink, 570, 570);}
              function red_click(){pageLink = 'https://www.reddit.com/submit?url={{ metadata.url }}{{ page.url }}';socialWindow(pageLink, 570, 570);}
              function pin_click(){pageLink = 'https://www.pinterest.com/pin/create/button/?&text={{title}}&url={{ metadata.url }}{{ page.url }}&description={{metadescription}}';socialWindow(pageLink, 570, 570);}
              function socialWindow(pageLink, width, height){var left = (screen.width - width) / 2;var top = (screen.height - height) / 2;var params = "menubar=no,toolbar=no,status=no,width=" + width + ",height=" + height + ",top=" + top + ",left=" + left;window.open(pageLink,"",params);}
            </script>
          </div>
          <div class="col-lg-8 post-content-block order-0 order-lg-2">
            <div data-pagefind-body class="content">
              {{ content | safe }}
            </div>




            <ul class="post-meta-tag list-unstyled list-inline mt-5">
              <li class="list-inline-item">Topics: </li>
              {% for tag in tags -%}
                  {% if tag !== 'post' %}
                      <li class="list-inline-item"><a class="bg-white" href="/topics/{{ tag | slugify}}">{{ tag | capitalize }}</a></li>
                  {% endif %}
              {%- endfor %}
            </ul>
          </div>
        </div>

      </div>
      
    </section>